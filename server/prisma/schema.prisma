// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  COMPRADOR
  FORNECEDOR
}

enum PedidoStatus {
  RASCUNHO
  PENDENTE
  APROVADO
  EM_TRANSITO
  ENTREGUE
  CANCELADO
}

enum AtaStatus {
  ATIVA
  VENCIDA
  CANCELADA
  EM_REVISAO
}

model User {
  id           String      @id @default(uuid())
  nome         String
  email        String      @unique
  senhaHash    String
  role         Role        @default(COMPRADOR)
  fornecedorId String?
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt
  auditorias   Auditoria[]

  @@map("usuarios")
}

model Ata {
  id             String           @id @default(uuid())
  numero         String           @unique
  vigenciaInicio DateTime
  vigenciaFim    DateTime
  valorTeto      Decimal          @db.Decimal(12, 2)
  fornecedorId   String
  status         AtaStatus        @default(ATIVA)
  criadoEm       DateTime         @default(now())
  atualizadoEm   DateTime         @updatedAt
  medicamentos   MedicamentoAta[]
  pedidos        PedidoCompra[]

  @@map("atas")
}

model MedicamentoAta {
  id            String   @id @default(uuid())
  ataId         String
  ata           Ata      @relation(fields: [ataId], references: [id])
  nome          String
  precoUnitario Decimal  @db.Decimal(10, 2)
  qtdeInicial   Int
  precoBPS      Decimal? @db.Decimal(10, 2)
  precoCMED     Decimal? @db.Decimal(10, 2)
  criadoEm      DateTime @default(now())

  @@map("medicamentos_ata")
}

model PedidoCompra {
  id           String       @id @default(uuid())
  status       PedidoStatus @default(PENDENTE)
  ataId        String
  ata          Ata          @relation(fields: [ataId], references: [id])
  valorTotal   Decimal      @db.Decimal(12, 2)
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt

  @@index([ataId])
  @@index([status])
  @@map("pedidos_compra")
}

model Auditoria {
  id            String   @id @default(uuid())
  dataHora      DateTime @default(now())
  usuarioId     String
  usuario       User     @relation(fields: [usuarioId], references: [id])
  acao          String
  entidadeId    String
  dadosAntes    Json?
  dadosDepois   Json?
  justificativa String?

  @@index([usuarioId])
  @@index([dataHora])
  @@map("auditorias")
}
